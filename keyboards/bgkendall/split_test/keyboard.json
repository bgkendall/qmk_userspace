{
    "keyboard_name": "BGK Split Test",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "build": {
        "lto": true
    },
    "usb": {
        "vid": "0x424B",
        "pid": "0x1122",
        "device_version": "0.0.1",
        "max_power": 100
    },
    "features": {
        "bootmagic": true,
        "command": false,
        "console": false,
    },
    "diode_direction": "COL2ROW",
    "matrix_pins": {
        "rows": ["GP5", "GP6"],
        "cols": ["GP7", "GP8"]
    },
    "split": {
        "enabled": true,
        "serial": {
            "driver": "vendor"
        },
        "transport": {
            "protocol": "serial"
        },
        "matrix_pins": {
            "right": {
                "rows": ["GP2", "GP3"],
                "cols": ["GP4", "GP5"]
            }
        }
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                { "matrix": [0, 0], "x": 0, "y": 0 },
                { "matrix": [0, 1], "x": 2, "y": 0 },
                { "matrix": [1, 0], "x": 3, "y": 0 },
                { "matrix": [1, 1], "x": 4, "y": 0 },
                { "matrix": [2, 0], "x": 0 , "y": 1 },
                { "matrix": [2, 1], "x": 2, "y": 1 },
                { "matrix": [3, 0], "x": 3, "y": 1 },
                { "matrix": [3, 1], "x": 4, "y": 1 }
            ]
        }
    }
}
